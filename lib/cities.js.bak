export const SERVICES = [
  { slug: 'emergency',          name: 'Emergency Plumbing',  shortName: 'Emergency',    description: '24/7 emergency plumbing dispatch',                  keywords: ['emergency plumber', '24/7 plumber', 'urgent plumbing'] },
  { slug: 'leak-repair',        name: 'Leak Repair',         shortName: 'Leak Repair',  description: 'Fast pipe and faucet leak detection and repair',     keywords: ['leak repair', 'pipe leak', 'water leak'] },
  { slug: 'drain-cleaning',     name: 'Drain Cleaning',      shortName: 'Drain',        description: 'Professional drain cleaning and sewer clearing',     keywords: ['drain cleaning', 'clogged drain', 'blocked drain'] },
  { slug: 'pipe-burst-repair',  name: 'Pipe Burst Repair',   shortName: 'Pipe Burst',   description: 'Emergency burst and frozen pipe repair',             keywords: ['burst pipe', 'broken pipe', 'frozen pipe'] },
  { slug: 'water-heater-repair',name: 'Water Heater Repair', shortName: 'Water Heater', description: 'Water heater repair, replacement, and installation', keywords: ['water heater repair', 'hot water heater', 'tankless'] },
];

export function cityToSlug(cityName) {
  return cityName.toLowerCase().replace(/\s+/g, '-');
}

export function buildSlug(citySlug, serviceSlug) {
  if (serviceSlug) return `plumber-${citySlug}-${serviceSlug}`;
  return `plumber-${citySlug}`;
}

export function parseSlug(fullSlug) {
  if (!fullSlug || !fullSlug.startsWith('plumber-')) return null;
  const withoutPrefix = fullSlug.replace(/^plumber-/, '');
  const service = SERVICES.find(s => withoutPrefix.endsWith(`-${s.slug}`));
  if (service) {
    const citySlug = withoutPrefix.slice(0, -(service.slug.length + 1));
    return { citySlug, service };
  }
  return { citySlug: withoutPrefix, service: null };
}

export function getCityBySlug(slug) {
  return SEED_CITIES.find(c => cityToSlug(c.name) === slug) || null;
}

